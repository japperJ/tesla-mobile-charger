# Tesla credentials (stored encrypted in DB, but initial seed via env)
TESLA_ENCRYPTION_KEY=change-this-to-a-random-32-char-secret

# App settings
PORT=4002
NODE_ENV=production

# ntfy.sh
NTFY_SERVER=https://ntfy.sh
